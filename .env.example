# Credenciales OAuth de Google. La entrada con Google ES el login de la app
# (y concede los permisos de Drive para generar los PDF con paginación
# exacta). Cómo obtenerlas:
#
#   1. https://console.cloud.google.com → crea (o elige) un proyecto.
#   2. "APIs y servicios" → "Biblioteca" → activa **Google Drive API** y
#      **Google Sheets API** (Drive genera los PDF; Sheets lee hojas privadas).
#   3. "Pantalla de consentimiento OAuth" → tipo **Interno** (solo miembros de
#      tu organización de Google Workspace pueden entrar).
#   4. "Credenciales" → "Crear credenciales" → "ID de cliente de OAuth" →
#      tipo "Aplicación web" → en "URIs de redireccionamiento autorizados"
#      añade:  http://localhost:3000/oauth/callback
#   5. Copia el ID y el secreto aquí (archivo .env, no .env.example).
#
# La conexión de cada usuario (refresh token) se guarda en su fila de la
# tabla `users` de la base de datos.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Dominio de Google Workspace permitido para entrar. El servidor rechaza
# logins de cualquier otro dominio aunque la consola esté mal configurada.
# Vacío = cualquiera puede entrar (aceptable SOLO en desarrollo).
ALLOWED_GOOGLE_HD=mecides.es

# Base de datos (usuarios, sesiones, biblioteca de plantillas, historial).
# Arrancar con: docker compose up -d
DATABASE_URL=postgres://ttg:ttg@localhost:5433/ttg

# OPCIONAL — clave de API para el selector de archivos de Google (Picker),
# los botones de «Elegir de Drive» junto a los campos de plantilla/datos/carpeta.
#   1. En el MISMO proyecto de Google Cloud: "Biblioteca" → activa
#      **Google Picker API**.
#   2. "Credenciales" → "Crear credenciales" → "Clave de API".
#   3. Restríngela: restricción de API = solo "Google Picker API"; restricción
#      de aplicación = "Referentes HTTP" con http://localhost:3000/* (y el
#      dominio de producción).
# Sin clave, los botones quedan desactivados (pegar URLs sigue funcionando).
GOOGLE_API_KEY=

# OPCIONAL — clave de OpenAI para «Sugerir vínculos automáticamente» con IA
# (modelo gpt-5-mini; se envían nombres de campos/columnas y hasta 5 filas de
# muestra con valores truncados a 60 caracteres). Sin clave, el botón usa la
# heurística por similitud de nombres y avisa.
OPENAI_API_KEY=
